<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Si-Cuti (Node.js Version)</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-10 font-sans">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-6 text-blue-600">Si-Cuti - Dashboard (Express Edition)</h1>
        
        <form action="/add" method="POST" class="bg-white p-6 rounded shadow-md mb-8 space-y-4">
            <input type="text" name="name" placeholder="Nama Pegawai" required class="border p-2 w-full rounded">
            <select name="type" required class="border p-2 w-full rounded">
                <option value="Cuti Tahunan">Cuti Tahunan</option>
                <option value="Cuti Sakit">Cuti Sakit</option>
            </select>
            <textarea name="reason" placeholder="Alasan" required class="border p-2 w-full rounded"></textarea>
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Submit Form</button>
        </form>

        <div class="bg-white p-6 rounded shadow-md">
            <table class="w-full text-left border-collapse">
                <tr class="bg-gray-200">
                    <th class="p-3 border-b">Nama</th>
                    <th class="p-3 border-b">Status</th>
                    <th class="p-3 border-b">Aksi</th>
                </tr>
                <% requests.forEach(function(r) { %>
                <tr class="border-b">
                    <td class="p-3"><%= r.name %> (<%= r.type %>)</td>
                    <td class="p-3 font-bold <%= r.status === 'Approved' ? 'text-green-600' : 'text-yellow-600' %>">
                        <%= r.status %>
                    </td>
                    <td class="p-3 flex space-x-2">
                        <form action="/approve/<%= r.id %>" method="POST">
                            <button type="submit" class="bg-green-500 text-white px-3 py-1 rounded">Approve</button>
                        </form>
                        <form action="/delete/<%= r.id %>" method="POST">
                            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded">Delete</button>
                        </form>
                    </td>
                </tr>
                <% }); %>
            </table>
        </div>
    </div>
</body>
</html>